# ─────────────────────────────────────────────────────────────────────────────
# PDF Press — environment configuration
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_NAME="PDF Press"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Where the "Enterprise / contact / support" form is delivered:
CONTACT_TO_EMAIL="divinitycomicsinc@gmail.com"

# Secret used to sign session + admin JWTs (change this to a long random string)
AUTH_SECRET="change-me-to-a-long-random-secret-string"

# SQLite database file location (relative to project root)
DATABASE_PATH="./data/pdfpress.db"

# ── Bootstrap admin ──────────────────────────────────────────────────────────
# On first `npm run db:init` an admin account is created from these.
ADMIN_EMAIL="admin@pdfpress.app"
ADMIN_PASSWORD="change-me-please"

# ── Google reCAPTCHA (v2 Checkbox OR v3) ─────────────────────────────────────
# Used on EVERY form (signup, login, contact, admin login).
# Get keys at https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
# "v2" (checkbox) or "v3" (invisible score). Default v2.
NEXT_PUBLIC_RECAPTCHA_VERSION="v2"
# For v3 only: minimum passing score (0.0 - 1.0)
RECAPTCHA_V3_MIN_SCORE="0.5"

# ── PayPal (subscriptions) ───────────────────────────────────────────────────
# Get credentials at https://developer.paypal.com/dashboard/applications
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
# "sandbox" or "live"
PAYPAL_ENV="sandbox"
# Webhook id from the PayPal app's Webhooks section (used to verify signatures)
PAYPAL_WEBHOOK_ID=""

# PayPal subscription plan IDs (create these under a Product in the PayPal dashboard)
NEXT_PUBLIC_PAYPAL_PLAN_MONTHLY=""
NEXT_PUBLIC_PAYPAL_PLAN_YEARLY=""

# ── Pricing (display only — the real charge is set by the PayPal plan) ────────
NEXT_PUBLIC_PRICE_MONTHLY="12"
NEXT_PUBLIC_PRICE_YEARLY="120"
NEXT_PUBLIC_CURRENCY="USD"

# ── Free-tier gating ─────────────────────────────────────────────────────────
# Total free downloads before a cooldown, and cooldown length (hours).
NEXT_PUBLIC_FREE_DOWNLOAD_LIMIT="5"
NEXT_PUBLIC_FREE_COOLDOWN_HOURS="8"

# ── SMTP (contact form + notifications) ──────────────────────────────────────
# For Gmail, create an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="PDF Press <no-reply@pdfpress.app>"
