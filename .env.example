# ─────────────────────────────────────────────────────────────────────────────
# ImpositionPDF — environment configuration
# Copy this file to `.env.local`.
#
# Only the "REQUIRED" block is needed to boot. Everything else (reCAPTCHA,
# PayPal, SMTP, pricing, free-tier limits, site name) is managed at runtime from
# Admin → Settings and stored in the database — no rebuild needed. The vars below
# act only as initial fallbacks until the equivalent setting is saved in admin.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Secret used to sign session + admin JWTs. Generate: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-long-random-secret-string"
# SQLite database file location (relative to project root)
DATABASE_PATH="./data/impositionpdf.db"
# Public site URL (used for metadata / SEO)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Bootstrap admin — created once by `npm run db:init`
ADMIN_EMAIL="admin@impositionpdf.com"
ADMIN_PASSWORD="change-me-please"

# ── OPTIONAL (all editable in Admin → Settings) ──────────────────────────────
NEXT_PUBLIC_SITE_NAME="ImpositionPDF"
CONTACT_TO_EMAIL="divinitycomicsinc@gmail.com"

# Google reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_RECAPTCHA_VERSION="v2"
RECAPTCHA_V3_MIN_SCORE="0.5"

# PayPal (subscriptions). Webhook URL: https://YOUR_DOMAIN/api/paypal/webhook
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENV="sandbox"
PAYPAL_WEBHOOK_ID=""
NEXT_PUBLIC_PAYPAL_PLAN_MONTHLY=""
NEXT_PUBLIC_PAYPAL_PLAN_YEARLY=""

# Pricing (display only — actual charge is set by the PayPal plan)
NEXT_PUBLIC_PRICE_MONTHLY="12"
NEXT_PUBLIC_PRICE_YEARLY="120"
NEXT_PUBLIC_CURRENCY="USD"

# Free-tier gating
NEXT_PUBLIC_FREE_DOWNLOAD_LIMIT="5"
NEXT_PUBLIC_FREE_COOLDOWN_HOURS="8"

# SMTP (contact form)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ImpositionPDF <no-reply@impositionpdf.com>"
